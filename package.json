{
  "name": "prose-minion-monorepo",
  "private": true,
  "version": "1.10.4",
  "license": "SEE LICENSE IN apps/vscode-extension/LICENSE",
  "description": "Monorepo root for Prose Minion: one shared @prose-minion/core consumed by the VS Code extension (and a future desktop app). See migration-and-facelift/ + docs/adr/2026-06-16-monorepo-ports-and-adapters.md.",
  "repository": {
    "type": "git",
    "url": "https://github.com/okeylanders/prose-minion-vscode.git"
  },
  "homepage": "https://github.com/okeylanders/prose-minion-vscode#readme",
  "bugs": {
    "url": "https://github.com/okeylanders/prose-minion-vscode/issues"
  },
  "sponsor": {
    "url": "https://buymeacoffee.com/okeylanders"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w apps/vscode-extension",
    "watch": "npm run watch -w apps/vscode-extension",
    "prepackage": "npm run typecheck && npm test",
    "package": "npm run package -w apps/vscode-extension",
    "lint": "eslint packages apps --ext ts,tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:tier1": "jest --testPathPattern='(useMessageRouter|usePersistence|MessageHandler|useAnalysis|useMetrics)'",
    "typecheck": "npm run typecheck:core && npm run typecheck:webview && npm run typecheck:ext",
    "typecheck:core": "tsc --noEmit -p packages/core/tsconfig.json",
    "typecheck:webview": "tsc --noEmit -p packages/core/tsconfig.webview.json",
    "typecheck:ext": "tsc --noEmit -p apps/vscode-extension/tsconfig.json"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.3.0"
  }
}
